# Copy this file to .env and adjust values
# NEVER commit .env to version control

# Nginx container name (must match docker-compose service name)
NGINX_CONTAINER=sandbox-nginx

# Port Nginx listens on (host)
NGINX_PORT=80

# Control API port
API_PORT=8080

# Docker image used for sandbox app containers
APP_IMAGE=sandbox-app:latest

# Health poll interval in seconds
HEALTH_POLL_INTERVAL=30

# Flask debug mode (set to false in production)
FLASK_DEBUG=false
